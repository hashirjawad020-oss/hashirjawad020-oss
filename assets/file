<svg width="480" height="280" viewBox="0 0 480 280" xmlns="http://www.w3.org/2000/svg" role="img">
  <title>Hashir Jawad — Developer Card</title>
  <desc>Animated developer card for Hashir Jawad, Full Stack Developer, Year 1 at VVCE</desc>

  <defs>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&amp;display=swap');

      .mono { font-family: 'Space Mono', 'Courier New', monospace; }

      /* Fade in entire card */
      .card-body { animation: fadeIn 0.6s ease both; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

      /* XP bar fill */
      .xp-fill { animation: xpGrow 1.8s 0.8s cubic-bezier(0.4,0,0.2,1) both; }
      @keyframes xpGrow { from { width: 0; } to { width: 200px; } }

      /* Skill bars */
      .bar-react { animation: barReact 1.4s 0.9s cubic-bezier(0.4,0,0.2,1) both; }
      @keyframes barReact { from { width: 0; } to { width: 114px; } }

      .bar-supa { animation: barSupa 1.4s 1.0s cubic-bezier(0.4,0,0.2,1) both; }
      @keyframes barSupa { from { width: 0; } to { width: 106px; } }

      .bar-gym { animation: barGym 1.4s 1.1s cubic-bezier(0.4,0,0.2,1) both; }
      @keyframes barGym { from { width: 0; } to { width: 97px; } }

      .bar-sleep { animation: barSleep 1.4s 1.2s cubic-bezier(0.4,0,0.2,1) both; }
      @keyframes barSleep { from { width: 0; } to { width: 15px; } }

      /* Cursor blink */
      .cursor { animation: blink 1s step-end infinite; }
      @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0; } }

      /* Status dot pulse */
      .status-dot { animation: pulse 2s ease-in-out infinite; }
      @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

      /* Glitch on name */
      .glitch-r { animation: glitchR 4s 2s step-end infinite; }
      .glitch-b { animation: glitchB 4s 2s step-end infinite; }
      @keyframes glitchR {
        0%,89%,100% { transform: translateX(0); opacity: 0; }
        90% { transform: translateX(-2px); opacity: 0.7; }
        92% { transform: translateX(2px); opacity: 0.7; }
        94% { transform: translateX(0); opacity: 0; }
      }
      @keyframes glitchB {
        0%,91%,100% { transform: translateX(0); opacity: 0; }
        92% { transform: translateX(2px); opacity: 0.7; }
        94% { transform: translateX(-2px); opacity: 0.7; }
        96% { transform: translateX(0); opacity: 0; }
      }

      /* Scan line */
      .scan { animation: scanMove 5s linear infinite; }
      @keyframes scanMove { 0% { transform: translateY(-2px); opacity: 0.6; } 95% { opacity:0.6; } 100% { transform: translateY(282px); opacity:0; } }

      /* Corner brackets fade in */
      .corners { animation: fadeIn 1s 0.3s both; }

      /* Tags stagger in */
      .tag1 { animation: fadeIn 0.4s 1.4s both; }
      .tag2 { animation: fadeIn 0.4s 1.5s both; }
      .tag3 { animation: fadeIn 0.4s 1.6s both; }
      .tag4 { animation: fadeIn 0.4s 1.7s both; }
      .tag5 { animation: fadeIn 0.4s 1.8s both; }
    </style>

    <clipPath id="scan-clip">
      <rect x="0" y="0" width="480" height="280"/>
    </clipPath>
  </defs>

  <!-- Background -->
  <rect width="480" height="280" rx="12" fill="#0a0a0a"/>

  <!-- Grid lines -->
  <g opacity="0.04" stroke="#ffffff" stroke-width="0.5">
    <line x1="40" y1="0" x2="40" y2="280"/>
    <line x1="80" y1="0" x2="80" y2="280"/>
    <line x1="120" y1="0" x2="120" y2="280"/>
    <line x1="160" y1="0" x2="160" y2="280"/>
    <line x1="200" y1="0" x2="200" y2="280"/>
    <line x1="240" y1="0" x2="240" y2="280"/>
    <line x1="280" y1="0" x2="280" y2="280"/>
    <line x1="320" y1="0" x2="320" y2="280"/>
    <line x1="360" y1="0" x2="360" y2="280"/>
    <line x1="400" y1="0" x2="400" y2="280"/>
    <line x1="440" y1="0" x2="440" y2="280"/>
    <line x1="0" y1="40" x2="480" y2="40"/>
    <line x1="0" y1="80" x2="480" y2="80"/>
    <line x1="0" y1="120" x2="480" y2="120"/>
    <line x1="0" y1="160" x2="480" y2="160"/>
    <line x1="0" y1="200" x2="480" y2="200"/>
    <line x1="0" y1="240" x2="480" y2="240"/>
  </g>

  <!-- Scan line -->
  <g clip-path="url(#scan-clip)">
    <rect class="scan" x="0" y="0" width="480" height="2" fill="#00ff88" opacity="0.12"/>
  </g>

  <!-- Card border glow -->
  <rect width="480" height="280" rx="12" fill="none" stroke="#00ff88" stroke-width="1" opacity="0.15"/>

  <!-- Corner brackets -->
  <g class="corners" fill="none" stroke="#00ff88" stroke-width="2" stroke-linecap="round">
    <path d="M12 26 L12 12 L26 12"/>
    <path d="M454 12 L468 12 L468 26"/>
    <path d="M12 254 L12 268 L26 268"/>
    <path d="M454 268 L468 268 L468 254"/>
  </g>

  <!-- Main card content -->
  <g class="card-body">

    <!-- Avatar circle -->
    <circle cx="52" cy="52" r="22" fill="#111" stroke="#00ff88" stroke-width="1.5"/>
    <circle cx="52" cy="52" r="27" fill="none" stroke="#00ff88" stroke-width="0.5" opacity="0.25"/>
    <text x="52" y="57" text-anchor="middle" font-family="'Space Mono', monospace" font-size="12" font-weight="700" fill="#00ff88">HJ</text>

    <!-- Name with glitch layers -->
    <text class="glitch-r mono" x="86" y="46" font-size="18" font-weight="700" fill="#ff0055" clip-path="url(#scan-clip)">HASHIR JAWAD</text>
    <text class="glitch-b mono" x="86" y="46" font-size="18" font-weight="700" fill="#0088ff" clip-path="url(#scan-clip)">HASHIR JAWAD</text>
    <text x="86" y="46" font-family="'Space Mono', monospace" font-size="18" font-weight="700" fill="#f0f0f0" letter-spacing="0.04em">HASHIR JAWAD</text>

    <text x="86" y="62" font-family="'Space Mono', monospace" font-size="9" fill="#00ff88" letter-spacing="0.12em">FULL STACK DEV · YEAR 01 · VVCE</text>

    <!-- Badges -->
    <g class="tag1">
      <rect x="86" y="70" width="46" height="14" rx="3" fill="#00ff8812" stroke="#00ff88" stroke-width="0.5"/>
      <text x="109" y="80" text-anchor="middle" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88" letter-spacing="0.06em">REACT</text>
    </g>
    <g class="tag2">
      <rect x="136" y="70" width="62" height="14" rx="3" fill="#00ff8812" stroke="#00ff88" stroke-width="0.5"/>
      <text x="167" y="80" text-anchor="middle" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88" letter-spacing="0.06em">SUPABASE</text>
    </g>
    <g class="tag3">
      <rect x="202" y="70" width="56" height="14" rx="3" fill="#00ff8812" stroke="#00ff88" stroke-width="0.5"/>
      <text x="230" y="80" text-anchor="middle" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88" letter-spacing="0.06em">VERCEL</text>
    </g>
    <g class="tag4">
      <rect x="262" y="70" width="66" height="14" rx="3" fill="#00ff8812" stroke="#00ff88" stroke-width="0.5"/>
      <text x="295" y="80" text-anchor="middle" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88" letter-spacing="0.06em">TYPESCRIPT</text>
    </g>
    <g class="tag5">
      <rect x="332" y="70" width="54" height="14" rx="3" fill="#00ff8812" stroke="#00ff88" stroke-width="0.5"/>
      <text x="359" y="80" text-anchor="middle" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88" letter-spacing="0.06em">LOVABLE</text>
    </g>

    <!-- Divider -->
    <line x1="24" y1="96" x2="456" y2="96" stroke="#1e1e1e" stroke-width="0.5"/>

    <!-- Stat boxes -->
    <!-- Box 1: Projects Live -->
    <rect x="24" y="104" width="100" height="44" rx="5" fill="#0e0e0e" stroke="#1e1e1e" stroke-width="0.5"/>
    <text x="34" y="118" font-family="'Space Mono', monospace" font-size="8" fill="#555" letter-spacing="0.1em">PROJECTS LIVE</text>
    <text x="34" y="136" font-family="'Space Mono', monospace" font-size="13" font-weight="700" fill="#e0e0e0">2 <tspan fill="#00ff88">deployed</tspan></text>

    <!-- Box 2: Sleep -->
    <rect x="132" y="104" width="100" height="44" rx="5" fill="#0e0e0e" stroke="#1e1e1e" stroke-width="0.5"/>
    <text x="142" y="118" font-family="'Space Mono', monospace" font-size="8" fill="#555" letter-spacing="0.1em">SLEEP SCHED</text>
    <text x="142" y="136" font-family="'Space Mono', monospace" font-size="13" font-weight="700" fill="#ec4899">undefined</text>

    <!-- Box 3: Stack -->
    <rect x="240" y="104" width="100" height="44" rx="5" fill="#0e0e0e" stroke="#1e1e1e" stroke-width="0.5"/>
    <text x="250" y="118" font-family="'Space Mono', monospace" font-size="8" fill="#555" letter-spacing="0.1em">STACK DEPTH</text>
    <text x="250" y="136" font-family="'Space Mono', monospace" font-size="13" font-weight="700" fill="#e0e0e0">Full <tspan fill="#00ff88">↑</tspan></text>

    <!-- Box 4: Class -->
    <rect x="348" y="104" width="108" height="44" rx="5" fill="#0e0e0e" stroke="#1e1e1e" stroke-width="0.5"/>
    <text x="358" y="118" font-family="'Space Mono', monospace" font-size="8" fill="#555" letter-spacing="0.1em">CLASS</text>
    <text x="358" y="136" font-family="'Space Mono', monospace" font-size="13" font-weight="700" fill="#e0e0e0">CS <tspan fill="#00ff88">∞</tspan></text>

    <!-- Divider -->
    <line x1="24" y1="158" x2="456" y2="158" stroke="#1e1e1e" stroke-width="0.5"/>

    <!-- LEFT COLUMN: Skill bars -->
    <!-- React / TS -->
    <text x="24" y="172" font-family="'Space Mono', monospace" font-size="9" fill="#555">React/TS</text>
    <rect x="100" y="163" width="130" height="4" rx="2" fill="#1a1a1a"/>
    <rect class="bar-react" x="100" y="163" width="0" height="4" rx="2" fill="#00ff88"/>
    <text x="236" y="172" font-family="'Space Mono', monospace" font-size="9" fill="#444">88%</text>

    <text x="24" y="187" font-family="'Space Mono', monospace" font-size="9" fill="#555">Supabase</text>
    <rect x="100" y="178" width="130" height="4" rx="2" fill="#1a1a1a"/>
    <rect class="bar-supa" x="100" y="178" width="0" height="4" rx="2" fill="#f59e0b"/>
    <text x="236" y="187" font-family="'Space Mono', monospace" font-size="9" fill="#444">82%</text>

    <text x="24" y="202" font-family="'Space Mono', monospace" font-size="9" fill="#555">Gym</text>
    <rect x="100" y="193" width="130" height="4" rx="2" fill="#1a1a1a"/>
    <rect class="bar-gym" x="100" y="193" width="0" height="4" rx="2" fill="#3b82f6"/>
    <text x="236" y="202" font-family="'Space Mono', monospace" font-size="9" fill="#444">75%</text>

    <text x="24" y="217" font-family="'Space Mono', monospace" font-size="9" fill="#555">Sleep</text>
    <rect x="100" y="208" width="130" height="4" rx="2" fill="#1a1a1a"/>
    <rect class="bar-sleep" x="100" y="208" width="0" height="4" rx="2" fill="#ec4899"/>
    <text x="236" y="217" font-family="'Space Mono', monospace" font-size="9" fill="#444">12%</text>

    <!-- XP bar -->
    <text x="24" y="234" font-family="'Space Mono', monospace" font-size="8" fill="#555" letter-spacing="0.08em">XP · YEAR 1</text>
    <text x="456" y="234" text-anchor="end" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88">6,030 / 9,000</text>
    <rect x="24" y="238" width="432" height="5" rx="2.5" fill="#1a1a1a"/>
    <rect class="xp-fill" x="24" y="238" width="0" height="5" rx="2.5" fill="#00ff88" opacity="0.9"/>

    <!-- Divider -->
    <line x1="24" y1="254" x2="456" y2="254" stroke="#1e1e1e" stroke-width="0.5"/>

    <!-- RIGHT COLUMN: Terminal lines + status -->
    <!-- Terminal lines -->
    <text x="24" y="267" font-family="'Space Mono', monospace" font-size="9" fill="#00ff88">▸</text>
    <text x="36" y="267" font-family="'Space Mono', monospace" font-size="9" fill="#666">tracademia.app</text>
    <text x="140" y="267" font-family="'Space Mono', monospace" font-size="9" fill="#00ff88">LIVE</text>

    <text x="200" y="267" font-family="'Space Mono', monospace" font-size="9" fill="#00ff88">▸</text>
    <text x="212" y="267" font-family="'Space Mono', monospace" font-size="9" fill="#666">vvce-connect</text>
    <text x="310" y="267" font-family="'Space Mono', monospace" font-size="9" fill="#00ff88">LIVE</text>

    <!-- Status bottom right -->
    <circle class="status-dot" cx="380" cy="263" r="4" fill="#00ff88"/>
    <text x="390" y="267" font-family="'Space Mono', monospace" font-size="8" fill="#00ff88" letter-spacing="0.08em">BUILDING</text>
    <text x="390" y="277" font-family="'Space Mono', monospace" font-size="7" fill="#333">v1.0.24 · first year</text>

  </g>
</svg>
